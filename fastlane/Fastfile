default_platform(:ios)

platform :ios do

  desc "Run unit tests"
  lane :test do
    run_tests(
      project: "Blackbook.xcodeproj",
      scheme: "BlackbookTests",
      devices: ["iPhone 16"],
      clean: true,
      code_coverage: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if is_ci

    match(
      type: "appstore",
      readonly: is_ci
    )

    if is_ci
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "Blackbook.xcodeproj",
        team_id: "37NR4Z7NT6",
        profile_name: ENV["sigh_com.blackbookdevelopment.app_appstore_profile-name"] || "match AppStore com.blackbookdevelopment.app",
        code_sign_identity: "Apple Distribution"
      )
    end

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    )

    build_app(
      project: "Blackbook.xcodeproj",
      scheme: "Blackbook",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      clean: true,
      include_bitcode: false
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: ENV["APP_APPLE_ID"]
    )
  end

  desc "Build and submit for App Store review"
  lane :release do
    setup_ci if is_ci

    match(
      type: "appstore",
      readonly: is_ci
    )

    build_app(
      project: "Blackbook.xcodeproj",
      scheme: "Blackbook",
      export_method: "app-store",
      clean: true,
      include_bitcode: false
    )

    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true
    )
  end

end

platform :mac do

  desc "Run macOS unit tests"
  lane :test do
    run_tests(
      project: "Blackbook.xcodeproj",
      scheme: "BlackbookTests",
      destination: "platform=macOS",
      clean: true,
      code_coverage: true
    )
  end

  desc "Build and upload macOS app to TestFlight"
  lane :beta do
    setup_ci if is_ci

    match(
      type: "appstore",
      platform: "macos",
      additional_cert_types: ["mac_installer_distribution"],
      readonly: is_ci
    )

    if is_ci
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "Blackbook.xcodeproj",
        team_id: "37NR4Z7NT6",
        profile_name: ENV["sigh_com.blackbookdevelopment.app_appstore_macos_profile-name"] || "match AppStore com.blackbookdevelopment.app macos",
        code_sign_identity: "Apple Distribution"
      )
    end

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    )

    # Archive and export macOS app manually to avoid Fastlane's IPA validation bug
    archive_path = File.expand_path("~/Library/Developer/Xcode/Archives/Blackbook.xcarchive")
    export_path = File.expand_path("./build")

    sh("xcodebuild", "-scheme", "Blackbook", "-project", "Blackbook.xcodeproj",
       "-destination", "generic/platform=macOS",
       "-archivePath", archive_path,
       "clean", "archive")

    # Generate export options plist
    profile_name = ENV["sigh_com.blackbookdevelopment.app_appstore_macos_profile-name"] || "match AppStore com.blackbookdevelopment.app macos"
    export_plist = Tempfile.new(["export", ".plist"])
    export_plist.write(<<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store-connect</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>com.blackbookdevelopment.app</key>
          <string>#{profile_name}</string>
        </dict>
      </dict>
      </plist>
    PLIST
    export_plist.close

    sh("xcodebuild", "-exportArchive",
       "-archivePath", archive_path,
       "-exportPath", export_path,
       "-exportOptionsPlist", export_plist.path)

    pkg_path = Dir["#{export_path}/*.pkg"].first
    UI.user_error!("No .pkg found in #{export_path}") unless pkg_path

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: ENV["APP_APPLE_ID"],
      pkg: pkg_path
    )
  end

  desc "Build macOS app for distribution"
  lane :build do
    build_mac_app(
      project: "Blackbook.xcodeproj",
      scheme: "Blackbook",
      destination: "generic/platform=macOS",
      clean: true,
      export_method: "app-store"
    )
  end

end

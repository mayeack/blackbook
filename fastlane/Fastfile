default_platform(:ios)

platform :ios do

  desc "Run unit tests"
  lane :test do
    run_tests(
      project: "Blackbook.xcodeproj",
      scheme: "BlackbookTests",
      devices: ["iPhone 16"],
      clean: true,
      code_coverage: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if is_ci

    match(
      type: "appstore",
      readonly: is_ci
    )

    if is_ci
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "Blackbook.xcodeproj",
        team_id: "37NR4Z7NT6",
        profile_name: ENV["sigh_com.blackbookdevelopment.app_appstore_profile-name"] || "match AppStore com.blackbookdevelopment.app",
        code_sign_identity: "Apple Distribution"
      )
    end

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    )

    build_app(
      project: "Blackbook.xcodeproj",
      scheme: "Blackbook",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      clean: true
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.expand_path("~/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build and submit for App Store review"
  lane :release do
    setup_ci if is_ci

    match(
      type: "appstore",
      readonly: is_ci
    )

    build_app(
      project: "Blackbook.xcodeproj",
      scheme: "Blackbook",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true
    )
  end

end

platform :mac do

  desc "Run macOS unit tests"
  lane :test do
    run_tests(
      project: "Blackbook.xcodeproj",
      scheme: "BlackbookTests",
      destination: "platform=macOS",
      clean: true,
      code_coverage: true
    )
  end

  desc "Build and upload macOS app to TestFlight"
  lane :beta do
    setup_ci if is_ci

    match(
      type: "appstore",
      platform: "macos",
      additional_cert_types: ["mac_installer_distribution"],
      readonly: is_ci
    )

    if is_ci
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "Blackbook.xcodeproj",
        team_id: "37NR4Z7NT6",
        profile_name: ENV["sigh_com.blackbookdevelopment.app_appstore_macos_profile-name"] || "match AppStore com.blackbookdevelopment.app macos",
        code_sign_identity: "Apple Distribution"
      )
    end

    # Use an offset build number from iOS to avoid App Store Connect conflicts
    # iOS build 42 → macOS build 100042 (separate number space, collision-proof)
    base = (ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")).to_i
    mac_build = (base + 100_000).to_s
    increment_build_number(
      build_number: mac_build
    )

    # Archive and export macOS app manually to avoid Fastlane's IPA validation bug
    # Note: sh() runs from fastlane/ dir, so use ../Blackbook.xcodeproj
    project_root = File.expand_path("..", FastlaneCore::FastlaneFolder.path)
    project_path = File.join(project_root, "Blackbook.xcodeproj")
    archive_path = File.join(project_root, "build", "Blackbook.xcarchive")
    export_path = File.join(project_root, "build")

    sh("xcodebuild", "-scheme", "Blackbook", "-project", project_path,
       "-destination", "generic/platform=macOS",
       "-archivePath", archive_path,
       "clean", "archive")

    # Generate export options plist
    profile_name = ENV["sigh_com.blackbookdevelopment.app_appstore_macos_profile-name"] || "match AppStore com.blackbookdevelopment.app macos"
    export_plist = Tempfile.new(["export", ".plist"])
    export_plist.write(<<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store-connect</string>
        <key>destination</key>
        <string>upload</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>installerSigningCertificate</key>
        <string>3rd Party Mac Developer Installer</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>com.blackbookdevelopment.app</key>
          <string>#{profile_name}</string>
        </dict>
      </dict>
      </plist>
    PLIST
    export_plist.close

    # Export and upload in one step via destination=upload in the plist.
    # Pass API key credentials explicitly so xcodebuild can authenticate with App Store Connect.
    key_path = File.expand_path("~/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8")
    sh("xcodebuild", "-exportArchive",
       "-archivePath", archive_path,
       "-exportPath", export_path,
       "-exportOptionsPlist", export_plist.path,
       "-authenticationKeyPath", key_path,
       "-authenticationKeyID", ENV["ASC_KEY_ID"],
       "-authenticationKeyIssuerID", ENV["ASC_ISSUER_ID"],
       "-allowProvisioningUpdates")
  end

end

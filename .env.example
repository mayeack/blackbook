# CI/CD and local deployment secrets (do not commit real values).
# Copy to .env or set in GitHub Actions Secrets.

# App Store Connect API Key (generate at App Store Connect > Users > Integrations)
ASC_KEY_ID=                  # Key ID from App Store Connect
ASC_ISSUER_ID=               # Issuer ID from App Store Connect
ASC_KEY_CONTENT=             # Base64-encoded .p8 file (CI only; locally place file at ~/private_keys/)

# App Store Connect
ITC_TEAM_ID=                 # App Store Connect team ID

# Fastlane Match (code signing)
MATCH_GIT_URL=               # Private git URL for certificates repo
MATCH_PASSWORD=              # Match encryption password
MATCH_GIT_BASIC_AUTHORIZATION=  # Base64(username:personal_access_token)
